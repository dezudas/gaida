{
  "name": "gaida",
  "version": "1.0.5",
  "description": "A minimalist CSS framework with modern grid system.",
  "homepage": "https://dezudas.github.io/gaida/",
  "repository": "dezudas/gaida",
  "license": "MIT",
  "author": "Dijup Tuladhar <dezudas@gmail.com>",
  "main": "dist/gaida.css",
  "keywords": [
    "css",
    "css3",
    "flexbox",
    "front-end",
    "framework",
    "html",
    "html5",
    "kickstarter",
    "postcss",
    "responsive",
    "sass",
    "scss",
    "mobile-first"
  ],
  "ignore": [
    ".appveyor.yml",
    ".editorconfig",
    ".eslintrc",
    ".github",
    ".gitignore",
    ".npmignore",
    ".sasslintrc",
    ".travis.yml",
    "changelog.md",
    "composer.json",
    "package.js",
    "package.json",
    "src",
    "test"
  ],
  "dependencies": {
    "normalize.css": "^8.0.1",
    "uipro-cli": "^2.2.3"
  },
  "devDependencies": {
    "autoprefixer": "^10.5.0",
    "browser-sync": "^3.0.4",
    "npm-run-all2": "^8.0.4",
    "onchange": "^7.1.0",
    "postcss": "^8.5.9",
    "postcss-cli": "^11.0.1",
    "rimraf": "^6.1.3",
    "sass": "^1.99.0"
  },
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "start": "run-p build watch serve",
    "build": "run-s clean sass autoprefixer",
    "clean": "rimraf dist",
    "sass": "sass --style=expanded src/gaida.scss dist/gaida.css && sass --style=compressed src/gaida.scss dist/gaida.min.css && sass --style=compressed src/gaida.scss docs/css/gaida.min.css",
    "autoprefixer": "postcss --use autoprefixer --no-map -r dist/*.css",
    "watch": "onchange \"src/**/*.scss\" -- run-s build",
    "serve": "browser-sync start --no-notify -s test --ss dist -f dist"
  },
  "bugs": {
    "url": "https://github.com/dezudas/gaida/issues",
    "email": "dezudas@gmail.com"
  },
  "directories": {
    "doc": "docs",
    "example": "examples",
    "test": "test"
  },
  "browserslist": [
    "last 2 major versions",
    ">= 1%",
    "Chrome >= 90",
    "Firefox >= 90",
    "Edge >= 90",
    "Safari >= 14",
    "iOS >= 14",
    "not dead"
  ]
}
